# ── VoiCit — configuration ────────────────────────────────────────────────
# Copiez ce fichier en .env.local et renseignez UNIQUEMENT la clé du
# fournisseur choisi. .env.local n'est JAMAIS commité (voir .gitignore).
# Toutes ces variables sont lues côté serveur uniquement.

# Fournisseur LLM actif : gemini | claude | openai
# Changer de fournisseur = changer CETTE ligne, rien d'autre dans le code.
LLM_PROVIDER=gemini

# Modèle à utiliser (optionnel). Vide = modèle par défaut du fournisseur.
# Exemples : gemini-2.5-flash | claude-haiku-4-5-20251001 | gpt-4o-mini
LLM_MODEL=

# Clés API — ne renseignez que celle du fournisseur sélectionné ci-dessus.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
